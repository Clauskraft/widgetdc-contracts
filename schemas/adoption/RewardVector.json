{
  "$id": "RewardVector",
  "description": "Multi-dimensional Q-learning reward signal",
  "type": "object",
  "required": [
    "quality",
    "latency",
    "cost",
    "satisfaction",
    "reliability"
  ],
  "properties": {
    "quality": {
      "minimum": 0,
      "maximum": 10,
      "description": "Output quality score",
      "type": "number"
    },
    "latency": {
      "minimum": 0,
      "maximum": 10,
      "description": "Speed score (10=fastest)",
      "type": "number"
    },
    "cost": {
      "minimum": 0,
      "maximum": 10,
      "description": "Cost efficiency (10=cheapest)",
      "type": "number"
    },
    "satisfaction": {
      "minimum": 0,
      "maximum": 10,
      "description": "User/agent satisfaction",
      "type": "number"
    },
    "reliability": {
      "minimum": 0,
      "maximum": 10,
      "description": "Completion without errors",
      "type": "number"
    }
  }
}
