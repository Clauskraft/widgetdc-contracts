{
  "$id": "HealthMetrics",
  "description": "CIA Health Metrics for consulting domains and intelligence assets",
  "type": "object",
  "required": [
    "score",
    "trend",
    "momentum",
    "resilience",
    "severity",
    "last_assessment"
  ],
  "properties": {
    "score": {
      "minimum": 0,
      "maximum": 100,
      "description": "Aggregated health score (0-100)",
      "type": "number"
    },
    "trend": {
      "description": "Directional health trend",
      "anyOf": [
        {
          "const": "up",
          "type": "string"
        },
        {
          "const": "down",
          "type": "string"
        },
        {
          "const": "stable",
          "type": "string"
        }
      ]
    },
    "momentum": {
      "description": "Rate of change per day",
      "type": "number"
    },
    "resilience": {
      "description": "Ability to recover from health dips",
      "type": "number"
    },
    "severity": {
      "$id": "RiskSeverity",
      "description": "CIA 3-tier risk severity classification",
      "anyOf": [
        {
          "const": "CRITICAL",
          "type": "string"
        },
        {
          "const": "WARNING",
          "type": "string"
        },
        {
          "const": "INFO",
          "type": "string"
        },
        {
          "const": "OPTIMAL",
          "type": "string"
        }
      ]
    },
    "last_assessment": {
      "format": "date-time",
      "description": "ISO-8601 timestamp of last analysis",
      "type": "string"
    }
  }
}
