{
  "$id": "IntelligenceObservation",
  "description": "A generic unit of intelligence extracted from any source",
  "type": "object",
  "required": [
    "observation_id",
    "source_type",
    "title",
    "content_summary",
    "actor_name",
    "metadata",
    "timestamp"
  ],
  "properties": {
    "observation_id": {
      "description": "Unique identifier (hash or source ID)",
      "type": "string"
    },
    "source_type": {
      "anyOf": [
        {
          "const": "MEDIA",
          "type": "string"
        },
        {
          "const": "CODE_REPO",
          "type": "string"
        },
        {
          "const": "FINANCIAL",
          "type": "string"
        },
        {
          "const": "GOVERNMENT_DATA",
          "type": "string"
        },
        {
          "const": "LEGAL_TENDER",
          "type": "string"
        },
        {
          "const": "CYBER_SIGNAL",
          "type": "string"
        }
      ]
    },
    "title": {
      "type": "string"
    },
    "content_summary": {
      "type": "string"
    },
    "actor_name": {
      "description": "e.g. Agency name or Vendor name",
      "type": "string"
    },
    "metadata": {
      "description": "Dynamic fields like budget, github_stars, or CVE_id",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "intelligence_score": {
      "$id": "WinProbabilityScore",
      "description": "Aggregated intelligence assessment",
      "type": "object",
      "required": [
        "overall_score",
        "confidence",
        "vectors",
        "is_go",
        "assessed_at"
      ],
      "properties": {
        "overall_score": {
          "minimum": 0,
          "maximum": 100,
          "description": "Final aggregated 0-100 win probability",
          "type": "number"
        },
        "confidence": {
          "minimum": 0,
          "maximum": 1,
          "description": "Statistical confidence in the prediction",
          "type": "number"
        },
        "vectors": {
          "description": "The individual factors making up the score",
          "type": "array",
          "items": {
            "$id": "SalienceVector",
            "description": "Generic weighted score component based on CIA methodology",
            "type": "object",
            "required": [
              "dimension",
              "raw_value",
              "weight",
              "score"
            ],
            "properties": {
              "dimension": {
                "description": "e.g., DomainMatch, ResourceAvailability",
                "type": "string"
              },
              "raw_value": {
                "minimum": 0,
                "maximum": 1,
                "description": "Raw calculated value",
                "type": "number"
              },
              "weight": {
                "minimum": 0,
                "description": "Importance multiplier for this use-case",
                "type": "number"
              },
              "score": {
                "description": "raw_value * weight",
                "type": "number"
              }
            }
          }
        },
        "is_go": {
          "description": "True if overall_score > threshold",
          "type": "boolean"
        },
        "assessed_at": {
          "format": "date-time",
          "type": "string"
        }
      }
    }
  }
}
