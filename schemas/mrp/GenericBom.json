{
  "$id": "GenericBom",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "product_type",
    "bom_version"
  ],
  "properties": {
    "product_type": {
      "$id": "ProductType",
      "description": "Kind of artifact the MRP pipeline should produce.",
      "anyOf": [
        {
          "const": "architecture",
          "type": "string"
        },
        {
          "const": "document",
          "type": "string"
        },
        {
          "const": "presentation",
          "type": "string"
        },
        {
          "const": "diagram",
          "type": "string"
        },
        {
          "const": "pdf",
          "type": "string"
        },
        {
          "const": "code",
          "type": "string"
        }
      ]
    },
    "bom_version": {
      "const": "2.0",
      "type": "string"
    }
  }
}
