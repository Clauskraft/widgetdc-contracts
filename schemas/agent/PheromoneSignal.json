{
  "$id": "PheromoneSignal",
  "description": "Stigmergic signal on the Omega blackboard",
  "type": "object",
  "required": [
    "id",
    "agent_id",
    "type",
    "domain",
    "content",
    "intensity",
    "ttl_hours",
    "deposited_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "agent_id": {
      "anyOf": [
        {
          "$id": "SubAgentId",
          "description": "Omega Sentinel sub-agent identifier",
          "anyOf": [
            {
              "const": "CLAUSE",
              "type": "string"
            },
            {
              "const": "SIGNAL",
              "type": "string"
            },
            {
              "const": "ARGUS",
              "type": "string"
            },
            {
              "const": "NEXUS",
              "type": "string"
            },
            {
              "const": "FISCAL",
              "type": "string"
            },
            {
              "const": "PIPELINE",
              "type": "string"
            },
            {
              "const": "SYNAPSE",
              "type": "string"
            },
            {
              "const": "ENGRAM",
              "type": "string"
            },
            {
              "const": "AEGIS",
              "type": "string"
            },
            {
              "const": "CLAW",
              "type": "string"
            }
          ]
        },
        {
          "const": "OMEGA",
          "type": "string"
        }
      ]
    },
    "type": {
      "$id": "PheromoneType",
      "description": "Pheromone signal type for stigmergic communication",
      "anyOf": [
        {
          "const": "INTEL",
          "type": "string"
        },
        {
          "const": "ALERT",
          "type": "string"
        },
        {
          "const": "STATUS",
          "type": "string"
        },
        {
          "const": "REQUEST",
          "type": "string"
        }
      ]
    },
    "domain": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "intensity": {
      "minimum": 0,
      "maximum": 1,
      "type": "number"
    },
    "ttl_hours": {
      "type": "number"
    },
    "deposited_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}
