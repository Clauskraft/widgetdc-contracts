        },
        {
          "const": "ARGUS",
          "type": "string"
        },
        {
          "const": "NEXUS",
          "type": "string"
        },
        {
          "const": "FISCAL",
          "type": "string"
        },
        {
          "const": "PIPELINE",
          "type": "string"
        },
        {
          "const": "SYNAPSE",
          "type": "string"
        },
        {
          "const": "ENGRAM",
          "type": "string"
        },
        {
          "const": "AEGIS",
          "type": "string"
        },
        {
          "const": "CLAW",
          "type": "string"
