{
  "$id": "LauncherExecution",
  "description": "Shared launcher execution contract.",
  "type": "object",
  "required": [
    "source",
    "summary",
    "trace",
    "metadata",
    "governance"
  ],
  "properties": {
    "source": {
      "minLength": 1,
      "description": "Execution source path, for example /reason or /api/rlm/ooda/run.",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "description": "Execution summary text returned by the current runtime path.",
      "type": "string"
    },
    "trace": {
      "description": "Runtime trace snippets suitable for cross-service debugging.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "$id": "LauncherExecutionMetadata",
      "description": "Shared launcher execution metadata used for runtime transparency. Surface-only wording fields belong elsewhere.",
      "additionalProperties": true,
      "type": "object",
      "properties": {
        "evidenceDomain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "reasonDomain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "canonicalGovernance": {
          "description": "Canonical backend governance snapshot. Exact shape should converge in dedicated backend schemas."
        },
        "retrievalSummary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "degradedReasoning": {
          "type": "boolean"
        },
        "fallbackToReason": {
          "type": "boolean"
        },
        "fallbackFrom": {
          "type": "string"
        },
        "fallbackError": {
          "type": "string"
        }
      }
    },
    "governance": {
      "$id": "LauncherGovernanceSummary",
      "description": "Read-only launcher governance rendering contract. Local-only governance context; not platform truth.",
      "type": "object",
      "required": [
        "promotionStatus",
        "gates",
        "targetKind",
        "boundaryOwner",
        "routePolicy",
        "promotionPolicy",
        "disclaimer"
      ],
      "properties": {
        "promotionStatus": {
          "anyOf": [
            {
              "const": "not_promoted",
              "type": "string"
            },
            {
              "const": "blocked",
              "type": "string"
            }
          ]
        },
        "looseEnd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "gates": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$id": "LauncherGovernanceGate",
            "description": "One launcher-local governance gate result.",
            "type": "object",
            "required": [
              "gate",
              "status",
              "reasonCode"
            ],
            "properties": {
              "gate": {
                "minLength": 1,
                "description": "Stable gate identifier.",
                "type": "string"
              },
              "status": {
                "anyOf": [
                  {
                    "const": "pass",
                    "type": "string"
                  },
                  {
                    "const": "fail",
                    "type": "string"
                  },
                  {
                    "const": "skip",
                    "type": "string"
                  },
                  {
                    "const": "coverage_gap",
                    "type": "string"
                  }
                ]
              },
              "reasonCode": {
                "minLength": 1,
                "description": "Machine-readable reason code for the gate outcome.",
                "type": "string"
              }
            }
          }
        },
        "targetKind": {
          "minLength": 1,
          "type": "string"
        },
        "boundaryOwner": {
          "minLength": 1,
          "type": "string"
        },
        "routePolicy": {
          "$id": "LauncherGovernanceRoutePolicy",
          "description": "Launcher-local route policy summary for operator visibility.",
          "type": "object",
          "required": [
            "foldingRequired",
            "retrievalRequired",
            "governanceRequired",
            "graphVerificationRequired",
            "renderValidationRequired"
          ],
          "properties": {
            "foldingRequired": {
              "type": "boolean"
            },
            "retrievalRequired": {
              "type": "boolean"
            },
            "governanceRequired": {
              "type": "boolean"
            },
            "graphVerificationRequired": {
              "type": "boolean"
            },
            "renderValidationRequired": {
              "type": "boolean"
            }
          }
        },
        "promotionPolicy": {
          "$id": "LauncherGovernancePromotionPolicy",
          "description": "Launcher-local promotion policy summary. Read-only and non-canonical.",
          "type": "object",
          "required": [
            "qualityGate",
            "policyAlignment",
            "graphWriteVerification",
            "readBackVerification",
            "looseEndGenerationOnFailureOrBlock"
          ],
          "properties": {
            "qualityGate": {
              "type": "boolean"
            },
            "policyAlignment": {
              "type": "boolean"
            },
            "graphWriteVerification": {
              "type": "boolean"
            },
            "readBackVerification": {
              "type": "boolean"
            },
            "looseEndGenerationOnFailureOrBlock": {
              "type": "boolean"
            }
          }
        },
        "disclaimer": {
          "minLength": 1,
          "description": "Must state that launcher governance checks are local and not canonical promotion authority.",
          "type": "string"
        }
      }
    }
  }
}
