{
  "$id": "OrchestratorToolCall",
  "description": "Agent → Orchestrator: request to invoke an MCP tool on the WidgeTDC backend. Orchestrator injects auth and handles SSE.",
  "type": "object",
  "required": [
    "call_id",
    "agent_id",
    "tool_name",
    "arguments"
  ],
  "properties": {
    "call_id": {
      "format": "uuid",
      "description": "Unique ID for this tool call (agent-generated UUID)",
      "type": "string"
    },
    "agent_id": {
      "description": "Canonical agent ID (e.g. CAPTAIN_CLAUDE, GEMINI_ARCHITECT, RLM_ENGINE)",
      "type": "string"
    },
    "tool_name": {
      "pattern": "^[a-z_]+\\.[a-z_]+$",
      "description": "MCP tool name in namespace.method format",
      "type": "string"
    },
    "arguments": {
      "description": "Tool-specific arguments (passed as payload to MCP route)",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    },
    "trace_id": {
      "format": "uuid",
      "type": "string"
    },
    "priority": {
      "default": "normal",
      "anyOf": [
        {
          "const": "low",
          "type": "string"
        },
        {
          "const": "normal",
          "type": "string"
        },
        {
          "const": "high",
          "type": "string"
        },
        {
          "const": "critical",
          "type": "string"
        }
      ]
    },
    "timeout_ms": {
      "minimum": 500,
      "maximum": 120000,
      "default": 30000,
      "type": "integer"
    },
    "emitted_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}
