{
  "$id": "artifact.request_review.envelope.v1",
  "description": "Shared artifact request-review envelope emitted by surfaces before canonical backend persistence.",
  "type": "object",
  "required": [
    "tool",
    "action",
    "artifact_id",
    "graph_write"
  ],
  "properties": {
    "tool": {
      "const": "artifacts.action",
      "type": "string"
    },
    "action": {
      "const": "request-review",
      "type": "string"
    },
    "artifact_id": {
      "minLength": 1,
      "type": "string"
    },
    "graph_write": {
      "$id": "ArtifactRequestReviewGraphWriteV1",
      "description": "Graph write instruction for artifact request-review envelopes.",
      "type": "object",
      "required": [
        "type",
        "request_kind",
        "requested_by",
        "artifact_id"
      ],
      "properties": {
        "type": {
          "const": "ConstructionRequest",
          "type": "string"
        },
        "request_kind": {
          "const": "REVIEW",
          "type": "string"
        },
        "requested_by": {
          "minLength": 1,
          "description": "Actor requesting review.",
          "type": "string"
        },
        "artifact_id": {
          "minLength": 1,
          "type": "string"
        }
      }
    }
  }
}
